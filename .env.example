# Bedtime Story Generator — environment-variable contract (V1 final state).
# Copy this file to .env and fill in any TBD values. .env is .gitignore'd.

# Backend env vars — read by app/main.py et al.
# In local dev, fill these in here; in production on Render, set them in the
# service's environment (DATABASE_URL is auto-wired from the managed Postgres
# add-on; GEMINI_API_KEY is set manually in the Render dashboard).

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_question_log
GEMINI_API_KEY=your-google-ai-studio-key-here

# Frontend (Module 7) — note: BACKEND_URL is NOT a backend env var.
# It's a JavaScript constant in frontend/script.js, replaced per-deploy:
#   - local dev:    const BACKEND_URL = "http://localhost:8000";
#   - production:   const BACKEND_URL = "https://bedtime-story-api.onrender.com";
# Vercel deploys the frontend as static files; there's no server-side render
# step, so we don't inject this via env var. Edit script.js directly.
